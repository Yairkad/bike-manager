{
  "expo": {
    "name": "ניהול מלאי אופניים",
    "slug": "bikeup",
    "owner": "yairkadoshs-organization",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f97316"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.ihud.bikemanager",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "12545a74-5739-40b4-8b98-e2c03816d836"
      }
    },
    "plugins": [
      ["expo-image-picker", {
        "photosPermission": "נדרשת גישה לתמונות כדי להוסיף תמונה לכלי",
        "cameraPermission": "נדרשת גישה למצלמה כדי לצלם תמונה לכלי"
      }]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/12545a74-5739-40b4-8b98-e2c03816d836"
    }
  }
}
